{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/sections/(.*)", "dest": "/sections/$1" },
    { "src": "/includes/(.*)", "dest": "/includes/$1" },
    { "src": "/contact.php", "dest": "/api/contact.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}